{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Vista",
  "version": "0.1.0",
  "identifier": "com.nyattic.vista",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vista",
        "width": 1200,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680,
        "maximized": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: vimg: http://vimg.localhost asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; script-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nyattic/Vista/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlBQTAwQTc1Qjc4QTdENEQKUldSTmZZcTNkUXFnbW5GRTRjSUxUeHJxeUFSM1FJbnpRSGYzTU1nTTBLQ1orVEZkT1pVUGxTSFMK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
